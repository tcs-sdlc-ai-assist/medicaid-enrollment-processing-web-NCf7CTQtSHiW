# Application title displayed in the browser tab and header
VITE_APP_TITLE=Medicaid Enrollment Portal

# Default user role for the application (e.g., applicant, caseworker, admin)
VITE_DEFAULT_ROLE=applicant

# Prefix used for localStorage/sessionStorage keys to avoid collisions
VITE_STORAGE_PREFIX=medicaid_

# Maximum file upload size in megabytes for document attachments
VITE_MAX_FILE_SIZE_MB=10